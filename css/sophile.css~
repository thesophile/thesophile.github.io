
h1 {margin:0px;}
h3 {margin-top:0px;}

.grey{
     background-color:#f2f2f2;
  } 

/*mac card###########################*/

.horflex{                                                       /*Flexed class*/
display:flex;
align-items:center;
}

@media only screen and (max-width: 770px ) {
   .horflex{
	display:flex;
	align-items:center;
	flex-direction:column;
}  
   
}

.card {
 width: 300px;
 height: 454px;
 margin:10px auto;
 background-color: #011522;
 border-radius: 8px;
 z-index: 1;
 text-align:center;
 box-shadow: 15px 15px 30px #bebebe,
             -15px -15px 30px #ffffff;
}

.card img {
width:10rem;
border-radius:50%;
transition: transform 0.3s ease;
cursor: pointer;
}

.card img:hover {
  transform: scale(1.1);
}

.card .subtitle{
  color:lightgrey;
  margin-top:1rem;
}

.card .title{
  color:white;
  margin-top:1rem;
}

.tools {
 display: flex;
 align-items: center;
 padding: 9px;
}

.circle {
 padding: 0 4px;
}

.box {
 display: inline-block;
 align-items: center;
 width: 10px;
 height: 10px;
 padding: 1px;
 border-radius: 50%;
}

.red {
 background-color: #ff605c;
}

.yellow {
 background-color: #ffbd44;
}

.green {
 background-color: #00ca4e;
}

.verflex{
	display:flex;
	align-items:center;
	flex-direction:column;
}

.verflex div{
	margin:10px;
}




.contact{
	margin-top:20px;	
}

.contact img{
	width:20px;
}

